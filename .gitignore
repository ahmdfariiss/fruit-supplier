# ============================================
# BuahKita Monorepo - .gitignore
# ============================================

# ---- Dependencies ----
node_modules/

# ---- Environment Variables ----
.env
.env.local
.env.*.local
.env.development
.env.production

# ---- Build Output ----
/frontend/.next/
/frontend/out/
/frontend/build/
/backend/dist/

# ---- Prisma Generated ----
/backend/generated/

# ---- Upload Files ----
/backend/uploads/

# ---- Documentation & Mockup (excluded) ----
DEPLOYMENT_VERCEL_RENDER.md
SPECIFICATION.md
docs.pdf
*.pdf
/ui/

# ---- OS Files ----
.DS_Store
Thumbs.db
desktop.ini

# ---- IDE / Editor ----
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# ---- Debug Logs ----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---- Testing ----
/frontend/coverage/
/backend/coverage/

# ---- Misc ----
*.pem
.pnp
.pnp.js
.yarn/install-state.gz
*.tsbuildinfo
next-env.d.ts
.vercel
