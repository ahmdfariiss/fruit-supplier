{
  "name": "buahkita",
  "version": "1.0.0",
  "description": "BuahKita - Platform Supplier Buah Segar",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "concurrently \"npm run build:backend\" \"npm run build:frontend\"",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "setup": "npm install && cd backend && npm install && npx prisma generate && cd ../frontend && npm install --legacy-peer-deps",
    "prisma:migrate": "cd backend && npx prisma migrate dev",
    "prisma:seed": "cd backend && npm run prisma:seed",
    "prisma:studio": "cd backend && npm run prisma:studio"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
